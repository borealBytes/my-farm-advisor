# OpenClaw Gateway - Coolify Deployment Environment Variables
# Copy this to .env and fill in your values before deploying to Coolify

# -----------------------------------------------------------------------------
# Security - REQUIRED
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=changeme

# -----------------------------------------------------------------------------
# Model Providers - REQUIRED (at least one)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

PRIMARY_MODEL=nvidia/stepfun-ai/step-3.5-flash
FALLBACK_MODELS=nvidia/qwen/qwen3.5-397b-a17b,nvidia/moonshotai/kimi-k2.5,openrouter/openrouter/free,openrouter/openai/gpt-5.4,openrouter/google/gemini-3.1-flash-lite-preview,openrouter/anthropic/claude-sonnet-4.6

# -----------------------------------------------------------------------------
# Telegram Channel - OPTIONAL
# -----------------------------------------------------------------------------
TELEGRAM_FIELD_OPERATIONS_BOT_TOKEN=...
TELEGRAM_FIELD_OPERATIONS_BOT_PAIRING_CODE=...
TELEGRAM_FIELD_OPERATIONS_ALLOWED_USERS=...
TELEGRAM_DATA_PIPELINE_BOT_TOKEN=...
TELEGRAM_DATA_PIPELINE_BOT_PAIRING_CODE=...
TELEGRAM_DATA_PIPELINE_ALLOWED_USERS=...
TELEGRAM_DATA_PIPELINE_BOT_ALLOWED_USERS=...
TELEGRAM_ALLOWED_USERS=...
TELEGRAM_ACCOUNT_ID=...
OPENCLAW_TELEGRAM_GROUP_POLICY=allowlist

# -----------------------------------------------------------------------------
# Cloudflare R2 Persistence (mount workspace/data when enabled)
# -----------------------------------------------------------------------------
R2_BUCKET_NAME=my-farm-advisor
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
CF_ACCOUNT_ID=...

# Data storage: bind (host path) or volume (Coolify persistent volume)
DATA_MODE=volume
# Mount workspace/data from R2 when set to 1
WORKSPACE_DATA_R2_RCLONE_MOUNT=0
WORKSPACE_DATA_R2_PREFIX=workspace/data

# -----------------------------------------------------------------------------
# Optional: Skill sync control
# -----------------------------------------------------------------------------
# OPENCLAW_SYNC_SKILLS_ON_START=1
OPENCLAW_SYNC_SKILLS_OVERWRITE=1
OPENCLAW_FORCE_SKILL_SYNC=0
OPENCLAW_MEMORY_SEARCH_ENABLED=0 
# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=America/Chicago
