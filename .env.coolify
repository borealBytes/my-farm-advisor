# OpenClaw Gateway - Coolify deployment environment variables
# Paste these into Coolify env vars or copy to `.env` for local compose testing.
# Local Docker does not require Cloudflare. In Coolify, leave
# `CLOUDFLARE_TUNNEL_TOKEN` blank to keep the gateway loopback/private by default.

# -----------------------------------------------------------------------------
# Security - REQUIRED
# Generate with: openssl rand -hex 32
# -----------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN=changeme

# -----------------------------------------------------------------------------
# Coolify access mode
# -----------------------------------------------------------------------------
# Optional: enables the same-compose `cloudflared` sidecar.
# Leave blank to keep Coolify private on 127.0.0.1:18789.
# After the tunnel path is healthy, remove any temporary direct public Coolify
# domain or raw-IP `http://` path so Cloudflare remains the only public entry.
CLOUDFLARE_TUNNEL_TOKEN=
# Required when the tunnel token is set. Example:
# my-farm-advisor.superiorbyteworks.com
OPENCLAW_PUBLIC_HOSTNAME=
# If browsers will also open a secondary pinned hostname, add that exact
# `https://...` origin to `gateway.controlUi.allowedOrigins` too.

# -----------------------------------------------------------------------------
# Model Providers - REQUIRED (at least one)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-v1-...
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

PRIMARY_MODEL=openrouter/openrouter/hunter-alpha
FALLBACK_MODELS=openrouter/openrouter/healer-alpha,openrouter/nvidia/nemotron-3-super-120b-a12b,openrouter/openrouter/free,nvidia/stepfun-ai/step-3.5-flash,nvidia/qwen/qwen3.5-397b-a17b,nvidia/moonshotai/kimi-k2.5,openrouter/stepfun/step-3.5-flash

# Optional Claude session bootstrap values
CLAUDE_AI_SESSION_KEY=
CLAUDE_WEB_SESSION_KEY=
CLAUDE_WEB_COOKIE=
OPENCLAW_ALLOW_INSECURE_PRIVATE_WS=

# -----------------------------------------------------------------------------
# Telegram Channel - OPTIONAL
# -----------------------------------------------------------------------------
TELEGRAM_FIELD_OPERATIONS_BOT_TOKEN=...
TELEGRAM_FIELD_OPERATIONS_BOT_PAIRING_CODE=...
TELEGRAM_FIELD_OPERATIONS_ALLOWED_USERS=...
TELEGRAM_DATA_PIPELINE_BOT_TOKEN=...
TELEGRAM_DATA_PIPELINE_BOT_PAIRING_CODE=...
TELEGRAM_DATA_PIPELINE_ALLOWED_USERS=...
TELEGRAM_DATA_PIPELINE_BOT_ALLOWED_USERS=...
TELEGRAM_BOT_TOKEN=...
TELEGRAM_ALLOWED_USERS=...
TELEGRAM_ACCOUNT_ID=...
OPENCLAW_TELEGRAM_GROUP_POLICY=allowlist

# -----------------------------------------------------------------------------
# Cloudflare R2 Persistence (mount workspace/data when enabled)
# -----------------------------------------------------------------------------
R2_BUCKET_NAME=my-farm-advisor
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
CF_ACCOUNT_ID=...

# Data storage: bind (host path) or volume (Coolify persistent volume)
DATA_MODE=volume
# Mount workspace/data from R2 when set to 1
WORKSPACE_DATA_R2_RCLONE_MOUNT=0
WORKSPACE_DATA_R2_PREFIX=workspace/data

# -----------------------------------------------------------------------------
# Optional: Skill sync control
# -----------------------------------------------------------------------------
# OPENCLAW_SYNC_SKILLS_ON_START=1
OPENCLAW_SYNC_SKILLS_OVERWRITE=1
OPENCLAW_FORCE_SKILL_SYNC=0
OPENCLAW_MEMORY_SEARCH_ENABLED=0

# Set to 1 for a one-time clean reseed of workspace/openclaw.json on next start,
# then set back to 0 after the refreshed deployment is healthy.
OPENCLAW_BOOTSTRAP_REFRESH=0
# -----------------------------------------------------------------------------
# Timezone
# -----------------------------------------------------------------------------
TZ=America/Chicago
