# OpenClaw .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local runs from this repo), OR to `~/.openclaw/.env` (for launchd/systemd daemons).
# 2) Fill only the values you use.
# 3) Keep real secrets out of git.
#
# Env-source precedence for environment variables (highest -> lowest):
# process env, ./.env, ~/.openclaw/.env, then openclaw.json `env` block.
# Existing non-empty process env vars are not overridden by dotenv/config env loading.
# Note: direct config keys (for example `gateway.auth.token` or channel tokens in openclaw.json)
# are resolved separately from env loading and often take precedence over env fallbacks.

# -----------------------------------------------------------------------------
# Gateway auth + paths
# -----------------------------------------------------------------------------
# Recommended if the gateway binds beyond loopback.
OPENCLAW_GATEWAY_TOKEN=change-me-to-a-long-random-token
# Example generator: openssl rand -hex 32

# Sync bundled skills into the workspace on startup (default: 1).
OPENCLAW_SYNC_SKILLS_ON_START=1
# When set, remove existing skill folders before copying (default: 1).
OPENCLAW_SYNC_SKILLS_OVERWRITE=1
# Retry count for each skill copy (default: 3).
# OPENCLAW_SYNC_SKILLS_RETRIES=3
# Strategy: auto (prefer AWS sync), api (force aws sync), fuse (force local copy).
# OPENCLAW_SKILL_SYNC_STRATEGY=auto
# Force a reseed even if manifest matches.
# OPENCLAW_FORCE_SKILL_SYNC=0
# Disable semantic memory search in regenerated configs (default: 0/false)
# OPENCLAW_MEMORY_SEARCH_ENABLED=0

# Browser control port publishing (host:port -> container:18791). Defaults to
# loopback-only so the browser server stays local on remote hosts.
OPENCLAW_BROWSER_CONTROL_PORT=18791
OPENCLAW_BROWSER_CONTROL_HOST=127.0.0.1
# Bind address inside the container for the browser control HTTP server.
OPENCLAW_BROWSER_CONTROL_BIND=127.0.0.1

# Optional alternative auth mode (use token OR password).
# OPENCLAW_GATEWAY_PASSWORD=change-me-to-a-strong-password

# Optional path overrides (defaults shown for reference).
# OPENCLAW_STATE_DIR=~/.openclaw
# OPENCLAW_CONFIG_PATH=~/.openclaw/openclaw.json
# OPENCLAW_HOME=~

# Optional: import missing keys from your login shell profile.
# OPENCLAW_LOAD_SHELL_ENV=1
# OPENCLAW_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Model provider API keys (set at least one)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...
# OPENROUTER_API_KEY=sk-or-...
# OPENCLAW_LIVE_OPENAI_KEY=sk-...
# OPENCLAW_LIVE_ANTHROPIC_KEY=sk-ant-...
# OPENCLAW_LIVE_GEMINI_KEY=...
# OPENAI_API_KEY_1=...
# ANTHROPIC_API_KEY_1=...
# GEMINI_API_KEY_1=...
# GOOGLE_API_KEY=...
# OPENAI_API_KEYS=sk-1,sk-2
# ANTHROPIC_API_KEYS=sk-ant-1,sk-ant-2
# GEMINI_API_KEYS=key-1,key-2

# Optional additional providers
# ZAI_API_KEY=...
# AI_GATEWAY_API_KEY=...
# MINIMAX_API_KEY=...
# SYNTHETIC_API_KEY=...

# -----------------------------------------------------------------------------
# Channels (only set what you enable)
# -----------------------------------------------------------------------------
# TELEGRAM_FIELD_OPERATIONS_BOT_TOKEN=123456:ABCDEF...
# TELEGRAM_FIELD_OPERATIONS_BOT_PAIRING_CODE=XXXXXXX
# TELEGRAM_FIELD_OPERATIONS_ALLOWED_USERS=123456789,987654321
# TELEGRAM_DATA_PIPELINE_BOT_TOKEN=654321:FEDCBA...
# TELEGRAM_DATA_PIPELINE_BOT_PAIRING_CODE=YYYYYYY
# TELEGRAM_DATA_PIPELINE_BOT_ALLOWED_USERS=123456789
# TELEGRAM_DATA_PIPELINE_ALLOWED_USERS=123456789
# TELEGRAM_ALLOWED_USERS=123456789,987654321
# OPENCLAW_TELEGRAM_GROUP_POLICY=allowlist
# DISCORD_BOT_TOKEN=...
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...

# Optional channel env fallbacks
# MATTERMOST_BOT_TOKEN=...
# MATTERMOST_URL=https://chat.example.com
# ZALO_BOT_TOKEN=...
# OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:...

# -----------------------------------------------------------------------------
# Tools + voice/media (optional)
# -----------------------------------------------------------------------------
# BRAVE_API_KEY=...
# PERPLEXITY_API_KEY=pplx-...
# FIRECRAWL_API_KEY=...

# ELEVENLABS_API_KEY=...
# XI_API_KEY=...  # alias for ElevenLabs
# DEEPGRAM_API_KEY=...

# -----------------------------------------------------------------------------
# Storage configuration (bind vs volume, optional R2 data mount)
# -----------------------------------------------------------------------------
# DATA_MODE describes how /data is provided:
# - bind   : host directory bind mount (default for local development)
# - volume : Docker-managed volume (e.g., Coolify deployment)
DATA_MODE=bind

# When enabled, mount Cloudflare R2 into /data/workspace/data (requires creds)
WORKSPACE_DATA_R2_RCLONE_MOUNT=0
# Remote prefix inside the bucket to mount (default: workspace/data)
WORKSPACE_DATA_R2_PREFIX=workspace/data

# Bind mount source used by docker-compose.yml when DATA_MODE=bind
# DATA_VOLUME_SOURCE=./data

# Coolify / production example:
# DATA_MODE=volume
# OPENCLAW_STATE_DIR=/data

# Cloudflare R2 credentials (required when WORKSPACE_DATA_R2_RCLONE_MOUNT=1)
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=...
# R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Rclone VFS cache settings (used when mounting R2)
# RCLONE_VFS_CACHE_SIZE=20G
# RCLONE_VFS_CACHE_MAX_AGE=1h
